# ==============================================================================
# Git Ignore Configuration for AI Waiter Project
# ==============================================================================

# Environment & Secrets
.env
.env.local
.env.*.local
!.env.template

# Python build and distribution
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python Virtual Environments
venv/
.venv/
env/
ENV/
pyenv/
.pytest_cache/
.coverage
htmlcov/

# ROS2 (Robot Operating System 2) Build Outputs
# In ROS2 workspaces (e.g., robot_ws), these directories are generated by colcon build
robot_ws/build/
robot_ws/install/
robot_ws/log/
install/
log/

# Frontend / Web Application Dependencies
node_modules/
dist/
out/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# IDEs and System Files
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# Project-Specific: RAG Databases & Pickled/Vector Indexes
# Ignore dynamically created SQLite DBs and vector store serialized files
storage/db/*.db
storage/vector/bm25.pkl
storage/vector/faiss_index/
data/vector_db/
data/sqlite/
data/samples/
**/pretrained_models/

# Project-Specific: Audio Input Assets
# Audio files (.wav) are extremely large and should not be checked into Git
inputs/audio/**/*.wav
data/audio_sources/

# Evaluation Runs & Developer Scratchpad
# Keep test datasets (evals/data/) but ignore dynamic evaluation results
evals/results/
scratch/
!scratch/.gitkeep

# Logs and Runtime Traces
*.log
logs/
